            "nl": "Noodstroom"
          }
        },
        {
          "id": "3",
          "label": {
            "en": "Off-Grid",
            "nl": "Off-Grid"
          }
        },
        {
          "id": "4",
          "label": {
            "en": "Peak Shaving",
            "nl": "Pieksturing"
          }
        },
        {
          "id": "5",
          "label": {
